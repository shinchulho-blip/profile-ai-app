# ================================================
# ProfileAI Environment Variables
# ================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ── App ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ProfileAI

# ── Cloudinary (Image Storage & Transformation) ──
# Docs: https://cloudinary.com/documentation/node_integration
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── Photoroom API (Background Removal) ──────────
# Docs: https://www.photoroom.com/api
# PHOTOROOM_API_KEY=your_photoroom_api_key

# ── Replicate API (AI Image Enhancement) ────────
# Docs: https://replicate.com/docs
# REPLICATE_API_TOKEN=your_replicate_token

# ── Database (optional, for user history) ───────
# DATABASE_URL=your_database_url

# ── Auth (optional) ─────────────────────────────
# NEXTAUTH_SECRET=your_nextauth_secret
# NEXTAUTH_URL=http://localhost:3000
